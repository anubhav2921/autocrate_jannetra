# JanNetra Frontend Configuration (Production/Local)

# IMPORTANT: All variables prefixed with VITE_ are exposed to the client
# If not set, the app will default to the production backend URL in apiClient.js

# Backend API URL (without trailing slash)
# Production Example: https://jannetra-web-production.up.railway.app
# Local Example: http://localhost:8000
VITE_API_URL=http://localhost:8000

# Firebase Configuration (for Client-side Auth)
VITE_FIREBASE_API_KEY=your_key
VITE_FIREBASE_AUTH_DOMAIN=your_app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_app_id
VITE_FIREBASE_STORAGE_BUCKET=your_app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_id
