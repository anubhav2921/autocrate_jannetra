# JanNetra Root Gitignore (Refactored)

# --- Secrets ---
.env
backend/.env
frontend/.env
serviceAccountKey.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*venv*/
venv/
venv311/
.venv/
.pyre*/
*.log

# --- Javascript / Node ---
node_modules/
dist/
dist_frontend/
frontend/dist/

# --- Databases & Reports ---
*.db
*.sqlite
*.sqlite3
*.json
!package.json
!package-lock.json
!backend/reports/*.json
!backend/scripts/**/*.json

# --- Tools & Temp ---
tmp/
*.txt
!requirements.txt
!*.example

# --- IDEs ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Structure Rules ---
# Keep all app source code
!backend/app/**/*.py
!frontend/src/**/*
!backend/scripts/**/*.py
!backend/data/

# Specific ignores for junk (already handled by extensions above generally)
# But we keep explicitly named tools if they are in scripts
!backend/run_backend.ps1
!README.md